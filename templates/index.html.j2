<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Ollama Benchmark – Latest Results</title>
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <style>
    body {font-family:Helvetica,Arial,sans-serif;margin:2rem;}
    table {border-collapse:collapse;width:100%;margin-top:1rem;}
    th, td {border:1px solid #ddd;padding:0.5rem;text-align:left;}
    th {background:#f4f4f4;}
    .error {color:#c00;}
    .sparkline { display:block; margin-top:4px; }
    .metric { font-variant-numeric: tabular-nums; }
    .mean { color: #888; font-size: 0.85em; }
    .model-chips { display:flex; flex-wrap:wrap; gap:0.4rem; margin-top:0.5rem; }
    .chip { padding:0.15rem 0.4rem; border-radius:4px; font-size:0.82rem; background:#eee; white-space:nowrap; }
    .chip.ok { background:#d1fae5; color:#065f46; }
    .chip.nok { background:#fee2e2; color:#991b1b; text-decoration:line-through; }
  </style>
</head>
<body>
  <h1>Ollama Cloud Benchmark – Latest Run</h1>
  <p>Generated {{ generated_at }}</p>

  <table>
    <thead>
      <tr>
        <th>Model</th>
        <th>Size</th>
        <th>Context</th>
        <th>Quant</th>
        <th>TTFT (s)</th>
        <th>TPS</th>
        <th>Error</th>
      </tr>
    </thead>
    <tbody>
      {% for row in results %}
      <tr>
        <td>{{ row.model }}</td>
        <td>{{ row.size }}</td>
        <td>{{ row.context }}</td>
        <td>{{ row.quant }}</td>
        <td class="metric">
          {% if row.ttft is not none %}{{ "%.2f"|format(row.ttft) }}{% else %}n/a{% endif %}
          {% if means.get(row.model, {}).get('ttft') is not none %}
            <span class="mean">({{ "%.2f"|format(means[row.model]['ttft']) }})</span>
          {% endif %}
          {{ sparklines[row.model].ttft | safe }}
        </td>
        <td class="metric">
          {% if row.tps is not none %}{{ "%.2f"|format(row.tps) }}{% else %}n/a{% endif %}
          {% if means.get(row.model, {}).get('tps') is not none %}
            <span class="mean">({{ "%.2f"|format(means[row.model]['tps']) }})</span>
          {% endif %}
          {{ sparklines[row.model].tps | safe }}
        </td>
        <td class="{% if row.error %}error{% endif %}">{{ row.error | default("—") }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <p>
    <small>
      Raw data: <a href="results.json">results.json</a> |
      History: <a href="history.json">history.json</a>
      (<a href="https://github.com/{{ github.repository }}/actions/runs/{{ github.run_id }}">GitHub run {{ github.run_number }}</a>)
    </small>
  </p>

  {% if free_models %}
  <hr>
  <h2>Free Account Model Availability</h2>
  <p>Tested {{ free_models.tested_at }} — {{ free_models.count_available }} / {{ free_models.count_total }} available</p>
  <div class="model-chips">
    {% for m in free_models.results %}
    <span class="chip {% if m.available %}ok{% else %}nok{% endif %}" title="{% if not m.available %}{{ m.error }}{% endif %}">{{ m.model }}</span>
    {% endfor %}
  </div>
  {% endif %}
</body>
</html>
